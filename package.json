{
  "name": "pi-extensions",
  "keywords": [
    "pi-package"
  ],
  "private": true,
  "pi-global": {
    "description": "npm global packages cần cài trước khi dùng Slnc_Pi",
    "required": [
      "@earendil-works/pi-coding-agent@^0.82.0",
      "@ast-grep/cli@^0.44.0",
      "@modelcontextprotocol/server-memory",
      "mcp-proxy"
    ]
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "extensions": [
      "./extensions"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "adm-zip": "^0.5.17",
    "ffmpeg-static": "^5.3.0",
    "open": "^10.2.0",
    "recheck": "^4.5.0",
    "ws": "^8.21.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "typebox": "^1.1.39",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
